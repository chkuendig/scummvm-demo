# -----------------------------------------------------------------------------
# Tooling secrets for the scummvm-demo deploy pipeline.
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored and must
# NEVER be committed. The same values are also configured as GitHub Actions
# secrets/variables so CI can use them (see docs/monitoring.md):
#   - secret:   SENTRY_AUTH_TOKEN
#   - variable: SENTRY_ORG, SENTRY_PROJECT, SENTRY_DSN, SENTRY_ENVIRONMENT
# The local `.env` lets us run sentry-cli / read issues from this machine.
# -----------------------------------------------------------------------------

# Sentry org and project slugs (from the project's Settings page URL).
SENTRY_ORG=
SENTRY_PROJECT=

# Client DSN for the browser SDK (safe to expose publicly; it is send-only).
# Used by the in-page Sentry init to send events. Project Settings -> Client Keys.
SENTRY_DSN=

# Internal Integration / auth token. SECRET. Used by sentry-cli in CI to upload
# debug files + source maps and create releases, and locally to read issues.
# Needs scopes: project:read, project:releases, org:read, event:read.
SENTRY_AUTH_TOKEN=

# Sentry server URL. Leave blank for SaaS (https://sentry.io). Set this only if
# self-hosting (e.g. GlitchTip): https://your-glitchtip-instance.example
SENTRY_URL=

# Environment tag attached to events (production / staging).
SENTRY_ENVIRONMENT=production

# Legacy: the Loader Script URL currently injected by the CI "Inject Sentry"
# step (vars.SENTRY_LOADER_URL). Kept for reference; superseded once we switch
# to the bundled @sentry/browser + @sentry/wasm init (needed for wasm frames).
SENTRY_LOADER_URL=
