precision highp float;

varying vec2 v_uv;

uniform sampler2D tex0;
uniform float gamma;

void main()
{
	vec4 color = texture2D(tex0, v_uv);
	float invGamma = 1.0 / gamma;
	gl_FragColor = vec4(pow(color.r, invGamma),
	                    pow(color.g, invGamma),
	                    pow(color.b, invGamma),
	                    color.a);
}
